rules_version = '2';

// ParkMate Firebase Storage security rules.
// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    // Community post photos: readable by any signed-in user, writable only by the owner.
    match /post-images/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Profile photos: readable by any signed-in user, writable only by the owner.
    match /profile_images/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && fileName.matches(request.auth.uid + '\\.jpg');
    }
  }
}
